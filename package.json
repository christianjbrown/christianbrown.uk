{
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "babel-jest": "^29.4.1",
    "babel-plugin-add-module-exports": "^1.0.4",
    "jest": "^29.4.1",
    "jest-environment-jsdom": "^29.4.1",
    "jest-fetch-mock": "^3.0.3",
    "jsdom": "^21.1.0"
  },
  "jest": {
    "bail":  true,
    "testEnvironment": "jsdom",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "assets/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "html"
    ],
    "coveragePathIgnorePatterns": [
      ".*/index.js",
      "_site/",
      "assets/js/plugins",
      "node_modules/"
    ],
    "testPathIgnorePatterns": [
      "_site/",
      "assets/js/plugins",
      "node_modules/"
    ]
  },
  "scripts": {
    "test": "jest --coverage"
  }
}
